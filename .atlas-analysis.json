  "keyFeatures": [
    "Menu browsing by nationality/category with item variants",
    "Order creation with main dishes and extra items",
    "Customer management with phone-based identification",
    "Order dispatch and status tracking",
    "Authentication with email/password and OAuth support",
    "Responsive design built with Tailwind CSS",
    "Edge runtime API routes for low-latency responses",
    "PostgreSQL database via Prisma ORM (Neon-compatible)"
  ],
  "publicApiSurface": [
    "POST /api/auth/login",
    "POST /api/auth/signUp",
    "POST /api/auth/logout",
    "GET /api/auth/oauth",
    "POST /api/auth/refreshSession",
    "POST /api/orders",
    "GET /api/orders",
    "PUT /api/orders/[orderId]/dispatch",
    "GET /api/customers",
    "GET /api/menu_items",
    "GET /api/menu_extras",
    "GET /api/nationalities"
  ]
